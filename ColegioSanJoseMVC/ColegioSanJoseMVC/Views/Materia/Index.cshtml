@model IEnumerable<ColegioSanJoseMVC.Models.Materia>

@{
    ViewData["Title"] = "Materias";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="bi bi-journal-bookmark"></i> Materias
        </h2>

        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nueva materia
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Materia</th>
                        <th>Docente</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreMateria</td>
                            <td>@item.Docente</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.MateriaId" class="btn btn-sm btn-warning text-white">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>

                                <a asp-action="Details" asp-route-id="@item.MateriaId" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i> Detalles
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.MateriaId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>