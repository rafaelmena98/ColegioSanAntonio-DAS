@model ColegioSanJoseMVC.Models.Materia

@{
    ViewData["Title"] = "Detalle de materia";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="bi bi-info-circle"></i> Detalle de materia
            </h4>
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nombre de la materia</dt>
                <dd class="col-sm-9">@Model.NombreMateria</dd>

                <dt class="col-sm-3">Docente</dt>
                <dd class="col-sm-9">@Model.Docente</dd>
            </dl>

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.MateriaId" class="btn btn-warning text-white">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver al listado
                </a>
            </div>
        </div>
    </div>
</div>