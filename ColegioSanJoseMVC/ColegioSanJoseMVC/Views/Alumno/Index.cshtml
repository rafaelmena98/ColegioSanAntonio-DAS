@model IEnumerable<ColegioSanJoseMVC.Models.Alumno>

@{
    ViewData["Title"] = "Alumnos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="bi bi-people"></i> Alumnos
        </h2>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Nuevo alumno
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Fecha de nacimiento</th>
                        <th>Grado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Apellido</td>
                            <td>@item.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                            <td>@item.Grado</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.AlumnoId" class="btn btn-sm btn-warning text-white">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>

                                <a asp-action="Details" asp-route-id="@item.AlumnoId" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i> Detalles
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.AlumnoId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>