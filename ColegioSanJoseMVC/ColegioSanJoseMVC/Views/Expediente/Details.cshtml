@model ColegioSanJoseMVC.Models.Expediente

@{
    ViewData["Title"] = "Detalle de expediente";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="bi bi-info-circle"></i>
                Detalle de expediente
            </h4>
        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-3">Alumno</dt>
                <dd class="col-sm-9">
                    @($"{Model.Alumno?.Nombre} {Model.Alumno?.Apellido}")
                </dd>

                <dt class="col-sm-3">Materia</dt>
                <dd class="col-sm-9">
                    @Model.Materia?.NombreMateria
                </dd>

                <dt class="col-sm-3">Nota final</dt>
                <dd class="col-sm-9">
                    @Model.NotaFinal
                </dd>

                <dt class="col-sm-3">Observaciones</dt>
                <dd class="col-sm-9">
                    @Model.Observaciones
                </dd>

            </dl>

            <div class="d-flex gap-2">

                <a asp-action="Edit"
                       asp-route-id="@Model.ExpedienteId"
                       class="btn btn-warning text-white">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>

                <a asp-action="Index"
                       class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Volver al listado
                </a>

            </div>

        </div>

    </div>

</div>