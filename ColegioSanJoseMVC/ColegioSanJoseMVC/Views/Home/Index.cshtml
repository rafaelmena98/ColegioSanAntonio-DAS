@{
    Layout = "_Layout";
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Colegio San José</h1>
        <p class="lead">
            Sistema web para la gestión de expedientes académicos, materias y calificaciones de alumnos.
        </p>
    </div>

    <div class="row text-center">

        <!-- Alumnos -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">Alumnos</h5>
                    <p class="card-text">
                        Registra y administra la información básica de los alumnos.
                    </p>
                    <a asp-controller="Alumno" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-person-badge"></i> Ir a alumnos
                    </a>
                </div>
            </div>
        </div>

        <!-- Materias -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">Materias</h5>
                    <p class="card-text">
                        Gestiona las materias ofrecidas por la institución.
                    </p>
                    <a asp-controller="Materia" asp-action="Index" class="btn btn-success">
                        <i class="bi bi-journal-bookmark"></i> Ir a materias
                    </a>
                </div>
            </div>
        </div>

        <!-- Expedientes -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">Expedientes</h5>
                    <p class="card-text">
                        Asocia alumnos con materias, notas finales y observaciones.
                    </p>
                    <a asp-controller="Expediente" asp-action="Index" class="btn btn-warning text-white">
                        <i class="bi bi-folder2-open"></i> Ir a expedientes
                    </a>
                </div>
            </div>
        </div>

        <!-- Promedios -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">Promedios</h5>
                    <p class="card-text">
                        Consulta el promedio de notas por alumno con gráficas estadísticas.
                    </p>
                    <a asp-controller="Reportes" asp-action="Promedios" class="btn btn-info text-white">
                        <i class="bi bi-bar-chart-line"></i> Ver promedios
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}